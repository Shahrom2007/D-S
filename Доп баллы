# возвращает объединение двух множеств (A ИЛИ B)
def SET_bin_union(A, B):
    # Элемент в объединении, если он есть хотя бы в одном из множеств
    return [A[i] or B[i] for i in range(10)]

# возвращает пересечение двух множеств (A И B)
def SET_bin_intersection(A, B):
    # Элемент в пересечении, только если он есть в обоих множествах сразу
    return [A[i] and B[i] for i in range(10)]

# возвращает разность двух множеств (A БЕЗ B)
def SET_bin_difference(A, B):
    # Элемент остается, если он был в A, но его НЕТ в B
    return [A[i] and not B[i] for i in range(10)]

# возвращает симметрическую разность двух множеств (только в одном из них)
def SET_bin_symm_difference(A, B):
    # Эквивалентно исключающему ИЛИ (XOR)
    return [A[i] ^ B[i] for i in range(10)]

# возвращает дополнение множества (НЕ A)
def SET_bin_complement(A):
    # Все, чего нет в A, становится частью дополнения
    return [int(not A[i]) for i in range(10)]
