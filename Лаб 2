int main(int argc, char *argv[]) {
    if (argc < 2) {
        printf("Usage: %s <input_file>\n", argv[0]);
        return 1;
    }

    FILE *F;
    POLY p;
    char S[256];

    F = fopen(argv[1], "r");
    if (F == NULL) {
        perror("Error opening file");
        return 1;
    }

    // Чтение количества точек
    if (fscanf(F, "%d", &p.n) != 1) return 1;
    p.p = (POINT *)malloc(p.n * sizeof(POINT));

    // Чтение имени многоугольника
    if (fscanf(F, "%255s", S) != 1) return 1;
    p.name = (char *)malloc(strlen(S) + 1);
    strcpy(p.name, S);

    // Чтение координат и имен точек
    for (int i = 0; i < p.n; i++) {
        if (fscanf(F, "%lf %lf %255s", &p.p[i].x, &p.p[i].y, S) != 3) break;
        p.p[i].name = (char *)malloc(strlen(S) + 1);
        strcpy(p.p[i].name, S);
    }

    // Вывод результатов
    printf("Polygon: %s\n", p.name);
    if (p.n >= 2) {
        printf("Dist (P0-P1): %lf\n", dist(&p.p[0], &p.p[1]));
    }
    printf("Perimeter: %lf\n", perimeter(&p));
    printf("Area: %lf\n", area(&p));
    printf("Diameter: %lf\n", diameter(&p));

    // Очистка памяти
    for (int i = 0; i < p.n; i++) {
        free(p.p[i].name);
    }
    free(p.p);
    free(p.name);
    fclose(F);

    return 0;
}
