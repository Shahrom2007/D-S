#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

// Структура точки
typedef struct point {
    double x;
    double y;
    char *name;
} POINT;

// Структура многоугольника
typedef struct poly {
    int n;
    POINT *p;
    char *name;
} POLY;

// Структура отрезка (сегмента)
typedef struct segm {
    POINT p1;
    POINT p2;
    char *name;
} SEGM;

// Расстояние между двумя точками
double dist(POINT *p1, POINT *p2) {
    register double t;
    return sqrt((t = (p2->x - p1->x)) * t + (t = (p2->y - p1->y)) * t);
}

// Периметр многоугольника
double perimeter(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += dist(&p->p[(i + 1) % p->n], &p->p[i]);
    }
    return s;
}

// Площадь многоугольника (формула Гаусса)
double area(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += (p->p[(i + 1) % p->n].x - p->p[i].x) * (p->p[(i + 1) % p->n].y + p->p[i].y);
    }
    return fabs(0.5 * s);
}

// Диаметр многоугольника (максимальное расстояние между вершинами)
double diameter(POLY *p) {
    double d = 0, t;
    for (int i = 0; i < p->n; i++) {
        for (int j = i + 1; j < p->n; j++) {
            if ((t = dist(&p->p[i], &p->p[j])) > d) {
                d = t;
            }
        }
    }
    return d;
}

// Определитель матрицы 3x3 (для проверки пересечения отрезков, как на фото)
double det(double m[3][3]) {
    return m[0][0]*m[1][1]*m[2][2] + m[0][1]*m[1][2]*m[2][0] + m[1][0]*m[2][1]*m[0][2] -
           m[2][0]*m[1][1]*m[0][2] - m[0][1]*m[1][0]*m[2][2] - m[1][2]*m[2][1]*m[0][0];
}

