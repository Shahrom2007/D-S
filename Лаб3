#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <math.h>

typedef struct point {
    double x;
    double y;
    char *name;
} POINT;


typedef struct poly {
    int n;
    POINT *p;
    char *name;
} POLY;


double dist(POINT *p1, POINT *p2) {
    register double t;
    
    return sqrt((t = (p2->x - p1->x)) * t + (t = (p2->y - p1->y)) * t);
}

double perimeter(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += dist(&p->p[(i + 1) % p->n], &p->p[i]);
    }
    return s;
}


double area(POLY *p) {
    double s = 0;
    for (int i = 0; i < p->n; i++) {
        s += (p->p[(i + 1) % p->n].x - p->p[i].x) * 
             (p->p[(i + 1) % p->n].y + p->p[i].y);
    }
    return fabs(0.5 * s);
}

double diameter(POLY *p) {
    double d = 0, t;
    for (int i = 0; i < p->n; i++) {
        for (int j = i + 1; j < p->n; j++) {
            if ((t = dist(&p->p[i], &p->p[j])) > d) {
                d = t;
            }
        }
    }
    return d;
}

int main(int argc, char *argv[]) {
    FILE *F;
    POLY p;
    char S[256];

    F = fopen(argv[1], "r");
    if (F == NULL) return 1;

    fscanf(F, "%d", &p.n);
    p.p = (POINT *)malloc(p.n * sizeof(POINT));

    fscanf(F, "%s", S);
    p.name = (char *)malloc(strlen(S) + 1);
    strcpy(p.name, S);

    for (int i = 0; i < p.n; i++) {
        fscanf(F, "%lf%lf%s", &p.p[i].x, &p.p[i].y, S);
        p.p[i].name = (char *)malloc(strlen(S) + 1);
        strcpy(p.p[i].name, S);
    }

    printf("%s %lf %lf %lf S=%lf D=%lf\n", 
           p.name, 
           dist(&p.p[0], &p.p[1]), 
           dist(&p.p[1], &p.p[2]), 
           perimeter(&p), 
           area(&p), 
           diameter(&p));

    fclose(F);
    return 0;
}
